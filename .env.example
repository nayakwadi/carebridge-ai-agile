# CareBridge environment configuration (copy to .env for local runs)
# docker-compose.yml already injects sensible defaults; this file documents
# every knob and supports running the backend outside Docker.

# --- Data tier ---
POSTGRES_USER=carebridge
POSTGRES_PASSWORD=carebridge
POSTGRES_DB=carebridge
DATABASE_URL=postgresql+psycopg://carebridge:carebridge@localhost:5432/carebridge

# --- Cache tier ---
REDIS_URL=redis://localhost:6379/0

# --- Application tier ---
# DEMO secret only. Never commit a real secret; load it from a secrets manager.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173

# --- Presentation tier ---
VITE_API_BASE_URL=http://localhost:8000
